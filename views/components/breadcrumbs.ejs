<section class="breadcrumbs">
    <div class="container">
        <ul class="breadcrumbs__list">
            <% breadcrumbs.map((breadcrumb) => { %>
                <li>
                    <a href="/<%=breadcrumb.url %>" class="link-primary"><%=breadcrumb.title%></a>
                </li>
           <% }) %>
        </ul>
    </div>
</section>